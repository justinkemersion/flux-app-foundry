# Optional branding (defaults derive from package.json name)
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_TAGLINE=

# Auth — set AUTH_SECRET and at least one provider pair
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Flux / PostgREST — see docs/FLUX_WORKFLOW.md
FLUX_URL=
FLUX_GATEWAY_JWT_SECRET=
# FLUX_POSTGREST_SCHEMA: do not set here (use .env.local from pnpm flux:schema:sync)
FLUX_TLS_INSECURE=0

# Demo seed — your OAuth sub after sign-in; optional placeholder subs for roommates
DEMO_USER_SUB=
DEMO_MEMBER_ALEX_SUB=demo-member-alex
DEMO_MEMBER_MARIA_SUB=demo-member-maria
